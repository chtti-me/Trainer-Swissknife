# ============ 資料庫（Supabase PostgreSQL + pgvector）============
# ⚠ Pooler 主機名請務必從 Supabase Dashboard → Settings → Database
#   → Connection string → Connection pooling 區塊複製。
#   專案不同可能落在 aws-0、aws-1、aws-2…（不是固定 aws-0），
#   填錯會出現 FATAL: Tenant or user not found。
# ⚠ 密碼若含特殊字元（@、#、!、/、:、空白等），務必做 URL encode：
#   例如 "Trainer@Pass" → "Trainer%40Pass"。
# Pooler（runtime 用，6543 port，pgbouncer transaction mode）
DATABASE_URL="postgresql://postgres.<project_ref>:<url_encoded_password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct 連線（migration 用，5432 port）
# 推薦走 pooler 的 5432 session mode（與 DATABASE_URL 同主機，僅換 port）；
# 若 db.<ref>.supabase.co 直連在 IPv6 only 環境（如 WSL）連不上，請一律用 pooler 5432。
DIRECT_URL="postgresql://postgres.<project_ref>:<url_encoded_password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# Supabase 專案資訊
SUPABASE_URL="https://<project_ref>.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_PUBLISHABLE_KEY=""

# 從 v3 升級時用：指向舊版 SQLite 備份檔，遷移腳本會讀取
LEGACY_SQLITE_URL="file:./prisma/dev.db.v3-backup.db"

# ============ NextAuth ============
NEXTAUTH_SECRET="please-change-this-in-production"
NEXTAUTH_URL="http://localhost:3001"
AUTH_TRUST_HOST=true

# ============ AI 供應商 ============
AI_PROVIDER="gemini"

OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_MODEL_PLANNING="gpt-4o"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

GEMINI_API_KEY=""
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_MODEL_PLANNING="gemini-2.5-flash"
# ⚠ Gemini OpenAI-compatible 端點目前不接受 "text-embedding-004"，
#   請使用 "gemini-embedding-001"（預設 3072 維，可透過 dimensions 參數截斷至 768）。
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"

NEXT_PUBLIC_AI_PROVIDER="openai"
NEXT_PUBLIC_AI_BASE_URL="https://api.openai.com/v1"
NEXT_PUBLIC_AI_MODEL="gpt-4o-mini"

# ============ 工具 ============
TAVILY_API_KEY=""

# ============ 相似度（v4 雙引擎）============
SIMILARITY_THRESHOLD=0.75
# 嵌入維度（必須與 prisma/schema.prisma 中 vector(N) 一致）
# - Gemini gemini-embedding-001 ➜ 建議 768（pgvector HNSW 索引上限為 2000，3072 不可用）
# - OpenAI text-embedding-3-small ➜ 1536
# 預設搭配 Gemini 採 768；若改用 OpenAI 請同時把 schema 的 vector(768) 改 vector(1536) 再 prisma db push。
EMBEDDING_DIMENSION=768
# 內容分數權重（lex + vec 會自動正規化為 1）
SIMILARITY_LEXICAL_WEIGHT=0.4
SIMILARITY_VECTOR_WEIGHT=0.6

APP_VERSION="v4.0"
