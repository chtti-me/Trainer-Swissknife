# 預設行為：依照 git core.autocrlf 設定
* text=auto

# 強制下列檔案使用 LF（Linux／macOS 換行符），避免在 Windows 編輯時被改成 CRLF
# 而導致在 WSL（Windows Subsystem for Linux）內 bash 解析失敗
# （例如 set -euo pipefail 被解讀成 pipefail\r 而報 "invalid option name"）
*.sh         text eol=lf
*.bash       text eol=lf
*.mjs        text eol=lf
*.cjs        text eol=lf
.nvmrc       text eol=lf
.editorconfig text eol=lf
.env*        text eol=lf

# Windows 批次檔仍以 CRLF 存放（雖然新版 cmd.exe 都接受 LF，CRLF 才是正規格式）
*.cmd        text eol=crlf
*.bat        text eol=crlf
*.ps1        text eol=crlf

# 二進位檔
*.png        binary
*.jpg        binary
*.ico        binary
*.pdf        binary
*.docx       binary
*.xlsx       binary
*.pptx       binary
*.woff       binary
*.woff2      binary
